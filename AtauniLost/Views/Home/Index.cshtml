@model IEnumerable<AtauniLost.Models.Ilanlar>
@{
    ViewData["Title"] = "Ana Sayfa - İlan Panosu";
}

<style>
    body {
        background-color: #0b132b; 
        color: white;
        background-image: url('/images/atauni-logo.png');
        background-repeat: no-repeat;
        background-position: center;
        background-attachment: fixed;
        background-size: 40%;
        image-rendering: auto;
    }

    body::before {
        content: "";
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background-color: rgba(11, 19, 43, 0.85);
        z-index: -1;
    }

    .card {
        background-color: #f8f9fa; /* Kırık beyaz */
        border: none;
        border-radius: 15px;
        color: #2b2d42;
        transition: 0.3s;
        overflow: hidden; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    .card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.5);
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
        background-color: #e9ecef;
    }

    .card-title {
        color: #1a5c8a;
        font-weight: bold;
    }

    .badge-durum {
        background-color: #5bc0be;
        color: #0b132b;
        font-weight: bold;
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px 12px;
        border-radius: 20px;
        z-index: 2;
    }

    /* OBS Stili Arama Kutusu */
    .search-input {
        background-color: #1c2541 !important;
        border: 1px solid #3a506b !important;
        color: white !important;
    }

    .search-input::placeholder {
        color: #6c757d;
    }

    .search-btn {
        background-color: #3a506b;
        border: 1px solid #3a506b;
        color: white;
        transition: 0.3s;
    }

    .search-btn:hover {
        background-color: #5bc0be;
        color: #0b132b;
    }

    .btn-detay {
        border-radius: 8px;
        border: 2px solid #1a5c8a;
        color: #1a5c8a;
        font-weight: bold;
    }

    .btn-detay:hover {
        background-color: #1a5c8a;
        color: white;
    }
</style>

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col-lg-5 col-md-12 mb-3 mb-lg-0">
            <h2 class="fw-bold text-white mb-0"><i class="bi bi-search"></i> Kampüste Neler Kayıp?</h2>
            <p class="text-info mb-0">Atatürk Üniversitesi güncel ilanları.</p>
        </div>

        <div class="col-lg-4 col-md-8 mb-3 mb-lg-0">
            <form asp-action="Index" method="get" class="d-flex">
                <div class="input-group shadow-sm">
                    <input type="text" name="search" class="form-control search-input" placeholder="Eşya veya yer ara..." aria-label="Arama">
                    <button class="btn search-btn" type="submit">
                        <i class="bi bi-search"></i> Ara
                    </button>
                </div>
            </form>
        </div>

        <div class="col-lg-3 col-md-4 text-end">
            <a href="/Ilan/Create" class="btn btn-info btn-lg fw-bold shadow w-100 w-md-auto" style="background-color: #5bc0be; border:none; color: #0b132b;">
                <i class="bi bi-plus-circle"></i> İlan Ver
            </a>
        </div>
    </div>

    @if (ViewBag.AramaSonucu != null)
    {
        <div class="alert d-flex justify-content-between align-items-center shadow-sm" style="background-color: #1c2541; border-left: 5px solid #5bc0be; color: white;">
            <span><i class="bi bi-info-circle me-2"></i> @ViewBag.AramaSonucu</span>
            <a href="/Home/Index" class="btn btn-sm btn-outline-light text-decoration-none">Filtreyi Temizle</a>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 position-relative">
                        <span class="badge badge-durum">@item.Durum</span>

                        @if (!string.IsNullOrEmpty(item.FotografYolu))
                        {
                            <img src="@item.FotografYolu" class="card-img-top" alt="Eşya Fotoğrafı">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center border-bottom">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Baslik</h5>
                            <p class="card-text text-truncate">@item.Aciklama</p>
                            
                            <div class="mt-auto">
                                <small class="text-muted d-block">
                                    <i class="bi bi-tag"></i> @item.Kategori
                                </small>
                                <small class="text-primary fw-bold">
                                    <i class="bi bi-geo-alt"></i> @item.Konum
                                </small>
                            </div>

                            <div class="d-grid mt-3">
                                <a href="/Ilan/Details/@item.IlanId" class="btn btn-detay">Detayları Gör</a>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <small class="text-muted">
                                <i class="bi bi-clock"></i> 
                                @(item.Tarih.HasValue ? item.Tarih.Value.ToString("dd.MM.yyyy HH:mm") : "Tarih Belirtilmedi")
                            </small>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center mt-5">
                <div class="p-5 border border-dashed rounded text-white" style="border: 2px dashed #5bc0be !important;">
                    <i class="bi bi-emoji-frown display-1" style="color: #5bc0be;"></i>
                    <h4 class="mt-3">Aramanızla eşleşen ilan bulunamadı.</h4>
                    <p class="text-info">Farklı kelimelerle aramayı deneyebilir veya yeni bir ilan verebilirsin.</p>
                    <a href="/Home/Index" class="btn btn-outline-info mt-3">Tüm İlanları Gör</a>
                </div>
            </div>
        }
    </div>
</div>