@model AtauniLost.Models.Ilanlar
@{
    ViewData["Title"] = "İlan Düzenle - Yönetici";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 bg-dark text-white p-4" style="border-radius: 15px;">
        <h2 class="fw-bold mb-4 text-accent"><i class="bi bi-pencil-square"></i> İlanı Güncelle (Yönetici Yetkisi)</h2>
        
        <form asp-controller="Admin" asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="IlanId" />
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">İlan Başlığı</label>
                    <input asp-for="Baslik" class="form-control bg-secondary text-white border-0" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Kategori</label>
                    <select asp-for="Kategori" class="form-select bg-secondary text-white border-0">
                        <option value="Elektronik">Elektronik</option>
                        <option value="Cüzdan">Cüzdan</option>
                        <option value="Anahtar">Anahtar</option>
                        <option value="Kart/Kimlik">Kart / Kimlik</option>
                        <option value="Çanta">Çanta</option>
                        <option value="Diğer">Diğer</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control bg-secondary text-white border-0" rows="4"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Konum</label>
                    <input asp-for="Konum" class="form-control bg-secondary text-white border-0" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Durum</label>
                    <select asp-for="Durum" class="form-select bg-secondary text-white border-0">
                        <option value="Kayıp">Kayıp</option>
                        <option value="Bulundu">Bulundu</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">İlan Onay Durumu</label>
                <div class="form-check form-switch">
                    @* HATA ÇÖZÜMÜ: Nullable bool hatası için asp-for yerine manuel kontrol kullanıyoruz *@
                    <input class="form-check-input" type="checkbox" 
                           id="OnayDurumu" 
                           name="OnayDurumu" 
                           value="true" 
                           @(Model.OnayDurumu == true ? "checked" : "")>
                    <input type="hidden" name="OnayDurumu" value="false">
                    
                    <label class="form-check-label text-info" for="OnayDurumu">Bu ilan ana sayfada görünsün mü?</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-5 fw-bold shadow">Değişiklikleri Kaydet</button>
                <a href="/Admin/Index" class="btn btn-outline-light">Vazgeç</a>
            </div>
        </form>
    </div>
</div>