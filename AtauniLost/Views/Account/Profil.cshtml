@model List<AtauniLost.Models.Ilanlar>
@{
    // Controller'dan gönderdiğimiz kullanıcı bilgisini alıyoruz
    var kullanici = ViewBag.Kullanici as AtauniLost.Models.Kullanicilar;
    ViewData["Title"] = "Profilim - " + (kullanici?.AdSoyad ?? "Kullanıcı");
}

<style>
    body { background-color: #0b132b; }

    /* Sol taraftaki Kişi Bilgi Kartı */
    .profile-sidebar {
        background: #1c2541;
        border-radius: 20px;
        padding: 30px;
        color: white;
        border: 1px solid #3a506b;
        position: sticky;
        top: 20px;
    }

    /* Sağ taraftaki İlan Kartları */
    .ilan-card {
        background: white;
        border-radius: 15px;
        padding: 15px;
        margin-bottom: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-left: 6px solid #5bc0be;
    }

    .ilan-card:hover {
        transform: translateX(10px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .user-avatar-circle {
        width: 110px;
        height: 110px;
        background: #5bc0be;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        margin: 0 auto 20px;
        color: #0b132b;
        box-shadow: 0 0 20px rgba(91, 192, 190, 0.3);
    }

    .status-badge {
        font-size: 0.75rem;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: bold;
    }

    .text-accent { color: #5bc0be; }
</style>

<div class="container mt-5">
    <div class="row">
        <!-- SOL PANEL: KİŞİ BİLGİLERİ (Merve Bölümü) -->
        <div class="col-lg-4 mb-4">
            <div class="profile-sidebar text-center shadow-lg">
                <div class="user-avatar-circle">
                    <i class="bi bi-person-fill"></i>
                </div>
                
                @* Giriş yapan kişinin ismi burada görünüyor *@
                <h3 class="fw-bold text-accent mb-1">@(kullanici?.AdSoyad ?? "Merve")</h3>
                <p class="text-muted small">@kullanici?.Email</p>
                
                <hr class="border-secondary my-4">
                
                <div class="text-start">
                    <div class="mb-3">
                        <label class="text-muted small d-block">Hesap Türü</label>
                        <span class="fw-bold"><i class="bi bi-shield-check text-success"></i> Standart Kullanıcı</span>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small d-block">Paylaşılan İlan Sayısı</label>
                        <span class="fw-bold fs-5">@Model.Count Adet</span>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small d-block">Üyelik Tarihi</label>
                        <span class="fw-bold">@DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="/Ilan/Create" class="btn btn-success w-100 rounded-pill mb-2">
                        <i class="bi bi-plus-lg"></i> Yeni İlan Ver
                    </a>
                    <a href="/Account/Logout" class="btn btn-outline-danger w-100 rounded-pill border-2">
                        <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                    </a>
                </div>
            </div>
        </div>

        <!-- SAĞ PANEL: İLANLARIM LİSTESİ -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4 ps-2">
                <h2 class="text-white fw-bold mb-0">İlan Yönetimi</h2>
                <span class="badge bg-primary rounded-pill px-3">Toplam @Model.Count İlan</span>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-light text-center py-5 shadow-sm border-0" style="border-radius: 15px;">
                    <i class="bi bi-emoji-smile display-4 text-muted"></i>
                    <h4 class="mt-3">Henüz bir ilanınız yok.</h4>
                    <p class="text-muted">Kaybettiğiniz veya bulduğunuz eşyalar için hemen bir ilan oluşturun!</p>
                </div>
            }

            @foreach (var ilan in Model)
            {
                <div class="ilan-card shadow-sm d-flex align-items-center">
                    <!-- İlan Fotoğrafı -->
                    <div class="flex-shrink-0">
                        @if (!string.IsNullOrEmpty(ilan.FotografYolu))
                        {
                            <img src="@ilan.FotografYolu" style="width: 100px; height: 100px; object-fit: cover; border-radius: 12px;">
                        }
                        else
                        {
                            <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 100px; height: 100px; border-radius: 12px;">
                                <i class="bi bi-image" style="font-size: 2rem;"></i>
                            </div>
                        }
                    </div>
                    
                    <!-- İlan Detayları -->
                    <div class="ms-4 flex-grow-1">
                        <h5 class="mb-1 fw-bold text-dark">@ilan.Baslik</h5>
                        <div class="mb-2">
                            <span class="text-muted small me-3"><i class="bi bi-tag-fill text-primary"></i> @ilan.Kategori</span>
                            <span class="text-muted small"><i class="bi bi-calendar3"></i> @ilan.Tarih?.ToString("dd MMM yyyy")</span>
                        </div>
                        
                        @if (ilan.OnayDurumu == true)
                        {
                            <span class="status-badge bg-success text-white shadow-sm"><i class="bi bi-check-circle-fill"></i> YAYINDA</span>
                        }
                        else
                        {
                            <span class="status-badge bg-warning text-dark shadow-sm"><i class="bi bi-clock-history"></i> ONAY BEKLİYOR</span>
                        }
                    </div>

                    <!-- İşlem Butonları -->
                    <div class="d-flex flex-column gap-2 ms-3">
                        <a href="/Ilan/Details/@ilan.IlanId" class="btn btn-outline-primary btn-sm px-3 rounded-pill">
                            <i class="bi bi-eye"></i> Görüntüle
                        </a>
                        <a href="/Ilan/Edit/@ilan.IlanId" class="btn btn-outline-warning btn-sm px-3 rounded-pill">
                            <i class="bi bi-pencil-square"></i> Düzenle
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>